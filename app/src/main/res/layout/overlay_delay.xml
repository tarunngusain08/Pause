<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <TextView
        android:id="@+id/overlay_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Take a breath."
        android:textColor="#1A1A2E"
        android:textSize="18sp"
        android:textStyle="normal" />

    <TextView
        android:id="@+id/overlay_app_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Opening app in..."
        android:textColor="#1A1A2E"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/overlay_countdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="10"
        android:textColor="#4A90A4"
        android:textSize="72sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/overlay_cancel_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:text="Cancel"
        android:textColor="#FFFFFF" />
</LinearLayout>
