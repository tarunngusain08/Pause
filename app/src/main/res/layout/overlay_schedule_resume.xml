<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <TextView
        android:id="@+id/schedule_resume_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Parental schedule active"
        android:textColor="#E0E0E0"
        android:textSize="18sp"
        android:textAlignment="center" />

    <TextView
        android:id="@+id/schedule_resume_band"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Current: Restricted"
        android:textColor="#4A90A4"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/schedule_resume_next"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Next change: 7:00 AM"
        android:textColor="#4A90A4"
        android:textSize="16sp" />

    <Button
        android:id="@+id/schedule_resume_got_it"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Got it"
        android:textColor="#FFFFFF" />
</LinearLayout>
