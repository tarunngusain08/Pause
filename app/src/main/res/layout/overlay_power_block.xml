<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <TextView
        android:id="@+id/power_block_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Power menu is disabled during Strict Mode"
        android:textColor="#1A1A2E"
        android:textSize="18sp"
        android:textAlignment="center" />

    <TextView
        android:id="@+id/power_block_remaining"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="0:00 remaining"
        android:textColor="#4A90A4"
        android:textSize="24sp" />

    <Button
        android:id="@+id/power_block_understand"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="I understand"
        android:textColor="#FFFFFF" />
</LinearLayout>
