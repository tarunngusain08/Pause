<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <TextView
        android:id="@+id/strict_block_app_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="App is blocked"
        android:textColor="#E0E0E0"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/strict_block_remaining"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="0:00 remaining"
        android:textColor="#4A90A4"
        android:textSize="24sp" />

    <TextView
        android:id="@+id/strict_block_dots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="○ ○ ○"
        android:textColor="#4A90A4"
        android:textSize="24sp"
        android:letterSpacing="0.2" />

    <Button
        android:id="@+id/strict_block_go_back"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginTop="32dp"
        android:text="Go Back"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4A90A4"
        android:paddingStart="32dp"
        android:paddingEnd="32dp" />

    <Button
        android:id="@+id/strict_block_emergency_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Emergency Exit ×3"
        android:textColor="#FFFFFF" />
</LinearLayout>
